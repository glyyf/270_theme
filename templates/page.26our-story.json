0,"padding-inline-end":0},"blocks":{}},"text_FU3z9K":{"type":"text","settings":{"text":"<p>Corey insists any design is fair game and they often experiment with new styles and materials.<\/p>","width":"100%","max_width":"narrow","alignment":"center","type_preset":"h2","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}}},"block_order":["image_E9LcNy","text_FU3z9K"],"name":"Laminator quote","settings":{"content_direction":"column","vertical_on_mobile":true,"horizontal_alignment":"flex-start","vertical_alignment":"center","align_baseline":false,"horizontal_alignment_flex_direction_column":"center","vertical_alignment_flex_direction_column":"center","gap":16,"section_width":"page-width","section_height":"","section_height_custom":50,"color_scheme":"","background_media":"none","video_position":"cover","background_image_position":"cover","border":"none","border_width":1,"border_opacity":100,"border_radius":0,"toggle_overlay":false,"overlay_color":"#00000026","overlay_style":"solid","gradient_direction":"to top","padding-block-start":64,"padding-block-end":64}},"section_JPUjWc":{"type":"section","blocks":{"group_tNVRPp":{"type":"group","settings":{"content_direction":"column","vertical_on_mobile":true,"horizontal_alignment":"flex-start","vertical_alignment":"center","align_baseline":false,"horizontal_alignment_flex_direction_column":"flex-end","vertical_alignment_flex_direction_column":"flex-start","gap":12,"width":"custom","custom_width":100,"width_mobile":"fill","custom_width_mobile":100,"height":"fill","custom_height":100,"inherit_color_scheme":true,"color_scheme":"","background_media":"none","video_position":"cover","background_image_position":"cover","border":"none","border_width":1,"border_opacity":100,"border_radius":0,"toggle_overlay":false,"overlay_color":"#00000026","overlay_style":"solid","gradient_direction":"to top","link":"","open_in_new_tab":false,"placeholder":"","padding-block-start":0,"padding-block-end":0,"padding-inline-start":0,"padding-inline-end":0},"blocks":{"text_fBmQXY":{"type":"text","settings":{"text":"<p>Corey’s father started shaping surfboards in the ’70s and has continued ever since. Growing up in that environment played a defining role in Corey’s childhood — his father taught him how to ride waves and, more importantly, how to shape his own boards.<\/p><p>As the primary laminator for respected local shapers such as Shane Stoneman (Stoneman Surfboards), Cooper Boneck (Mesa Surfboards), and the legendary Marc Andreini (Andreini Surfboards), Corey brings a wealth of hands-on experience to every board. We’re fortunate to have him leading the entire process — from shaping through to final quality control.<\/p><p>While ding repairs currently make up the majority of the business, designing and producing custom boards is the true soul of Nautilus. Corey is open to any design concept and loves experimenting with new styles and materials. That said, his real passion lies in emulating the classic shapes and aesthetics of the ’70s, ’60s, and even earlier eras.<\/p>","width":"fit-content","max_width":"normal","alignment":"left","type_preset":"h4","font":"var(--font-body--family)","font_size":"1rem","line_height":"normal","letter_spacing":"normal","case":"none","wrap":"pretty","color":"var(--color-foreground)","background":false,"background_color":"#00000026","corner_radius":0,"padding-block-start":0,"padding-block-end":10,"padding-inline-start":0,"padding-inline-end":0},"blocks":{}}},"block_order":["text_fBmQXY"]},"image_rLpWDN":{"type":"image","settings":{"image":"shopify:\/\/shop_images\/our-story-meet-the-laminator-main02.jpg","link":"","image_ratio":"square","width":"fill","custom_width":100,"width_mobile":"fill","custom_width